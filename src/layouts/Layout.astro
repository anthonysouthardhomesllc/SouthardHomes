---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg", 
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "Southard Homes LLC"
  : "Southard Homes LLC - Homes for Sale, Houses for Rent, and Rent-to-Own (RTO) in Terre Haute, Indiana"; 
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="facebook-domain-verification" content="2bk2n25ugleccm5htyqjku437niixm" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta property="og:image" content="https://southardhomesllc.com/opengraph.jpg" />

    <!-- GoatCounter Analytics  -->
    <script is:inline data-goatcounter="https://southard-analytics.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    <script>
      //Disable GoatCounter on localhost and staging environments
      if (window.location.host !== 'southardhomesllc.com')
          (window as any).goatcounter = {no_onload: true}
    </script>
    
    <SEO
      title={makeTitle}
      description="Southard Homes LLC is a local family-owned real estate, property development, and residential construction company serving the Wabash Valley since 2019. Looking for homes for sale, homes for rent, or rent to own (RTO) opportunities? Call us today!"
      canonical={canonicalURL}
      twitter={{ 
        creator: "@southardhomesllc",
        site: "https://www.facebook.com/p/Southard-Homes-LLC-61564654631774/",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `Southard Homes LLC - Homes for Sale, Houses for Rent, and Rent-to-Own (RTO) in Terre Haute, Indiana`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Southard Homes LLC Homepage Screenshot",
        },
      }}
    />
  </head>
  <body>
    
    <div class="top-0 w-screen z-50 bg-[#000000] shadow-lg">
      <Navbar />
    </div>

    <slot />
    
    <Footer />
    
    <style is:global>
      img {
        content-visibility: auto;
      }

      body {
        background-image: linear-gradient(black, #424036);
        color: #ffffff;
        min-height: 100vh;
      }

      a[href^="mailto:"] {
        color: #ffca28 !important;
        text-decoration: underline;
      }
    </style>
  </body>
</html>