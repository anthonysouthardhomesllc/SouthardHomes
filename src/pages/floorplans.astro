---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Sectionhead from "@components/sectionhead.astro";
import FloorplanCard from "@components/floorplanCard.astro";
---
<Layout title="Floorplans | Terre Haute, IN | Southard Homes LLC">
    <Container>
        <Sectionhead>
            <Fragment slot="title">New Home Floorplans</Fragment>
            <Fragment slot="desc">Your Dream Home, From The Ground Up</Fragment>
        </Sectionhead>
        
        <div class="text-lg mt-4 text-slate-600 pb-4">
            <p>
                Looking for a high-quality, beautifully designed home without the hassle of
                custom construction? Our <b>spec home floorplans</b> offer the perfect
                solution.
            </p>

            <p class="mt-4">
                Our <b>ready-to-build</b> options are crafted for efficiency, style, and
                comfort. Choose your favorite design, and we'll build it for you on your
                land. We also give you the freedom to <b>make your home uniquely yours</b>
                with options like:
            </p>

            <ul class="mt-2 ml-6 list-disc">
                <li>Flooring styles</li>
                <li>Countertops & cabinetry finishes</li>
                <li>Interior & exterior paint colors</li>
                <li>Siding colors and accents (brick or stone)</li>
                <li>And more, depending on availability!</li>
            </ul>

            <p class="mt-4">
                We're <b>always adding new designs!</b> If you're interested in building
                your dream home with us, or want to know more,
                <a
                href="tel:812-243-2759"
                class="text-[#ffca28] font-bold"
                >
                call Christa
                </a>
                today!
            </p>

            <p class="mt-4">
                Your dream home is closer than you think—let's make it happen!
            </p>

            <div class="mt-4 mb-6 text-center">
                <p class="inline-block rounded-lg px-6 py-3 font-semibold text-black shadow-md border-[#ffca28] border-2">
                    Ready to build? Call Christa at
                    <a
                        href="tel:812-243-2759"
                        class="underline hover:no-underline"
                    >
                        (812) 243-2759
                    </a>
                    for pricing, available options, and build timelines.
                </p>
            </div>
        </div>

        <div class="mt-4 flex flex-wrap flex-col md:flex-row gap-4 md:mx-0">
            <FloorplanCard
            floorplanImg="https://i.postimg.cc/rpfd7DcV/The-Sycamore.png"
