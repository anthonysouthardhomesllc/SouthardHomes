---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { v2 as cloudinary } from 'cloudinary';

//Load environment variables from .env file
const rawUrl = import.meta.env.CLOUDINARY_URL || process.env.CLOUDINARY_URL || '';

let cloudName = '';
let apiKey = '';
let apiSecret = '';

//Set up Cloudinary credentials from CLOUDINARY_URL if available
if (rawUrl && rawUrl.startsWith('cloudinary://')) {
  const cleanUrl = rawUrl.replace('cloudinary://', '');
  const [credentials, cloud] = cleanUrl.split('@');
  const [key, secret] = credentials.split(':');
  
  cloudName = cloud;
  apiKey = key;
  apiSecret = secret; 
}

//If CLOUDINARY_URL is not set or is invalid, fall back to individual environment variables
if (!cloudName) {
  cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || process.env.PUBLIC_CLOUDINARY_CLOUD_NAME || '';
  apiKey = import.meta.env.PUBLIC_CLOUDINARY_API_KEY || process.env.PUBLIC_CLOUDINARY_API_KEY || '';
  apiSecret = import.meta.env.CLOUDINARY_API_SECRET || process.env.CLOUDINARY_API_SECRET || '';
}

//Define an interface for gallery items
interface GalleryItem {
  url: string;
  largeUrl: string;
  publicId: string;
  date: Date;
}

//Inject variables straight into the configuration instance
cloudinary.config({
  cloud_name: cloudName,
  api_key: apiKey,
  api_secret: apiSecret,
  secure: true
});

const { resources } = await cloudinary.search
  .expression('folder:SHLLC-Gallery')
  .with_field('context')  
  .with_field('image_metadata') 
  .max_results(100)
  .execute();

const galleryItems: GalleryItem[] = resources.map((image: any) => {
  const optimizedUrl = image.secure_url.replace(
    '/upload/',
    '/upload/c_scale,w_400,h_400,f_auto,q_auto/' 
  );

  return {
    url: optimizedUrl,
    largeUrl: image.secure_url,
    publicId: image.public_id,
    date: image.image_metadata?.DateTimeOriginal 
      ? new Date(image.image_metadata.DateTimeOriginal) 
      : new Date(image.created_at),
  };
});

const sortedGallery = galleryItems.sort((a: GalleryItem, b: GalleryItem) => b.date.getTime() - a.date.getTime());
---

<Layout title="Gallery">
    <Container>
        <div class="bg-cover bg-center py-12 drop-shadow-sm">
            <Sectionhead>
                <Fragment slot="title">Gallery</Fragment>
                <Fragment slot="desc"></Fragment>
            </Sectionhead>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {sortedGallery.map((item) => (
            <div class="!bg-black rounded-lg overflow-hidden border-2 border-zinc-800 flex flex-col">
                <div class="aspect-video w-full overflow-hidden">
                    <img 
                        src={item.url} 
                        alt="Southard Homes construction project" 
                        class="w-full h-full object-cover hover:scale-102 transition-transform duration-300"
                        loading="lazy"
                    />
                </div>
                
                <div class="p-4 text-white mt-auto bg-black flex justify-between items-center text-sm">
                    <span>Date added: {item.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                </div>
            </div>
        ))}
        </div>
    </Container>
</Layout>