---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { v2 as cloudinary } from 'cloudinary';

// Define your interface for gallery items
interface GalleryItem {
  url: string;
  largeUrl: string;
  publicId: string;
  date: Date;
}

const cloudName = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || process.env.PUBLIC_CLOUDINARY_CLOUD_NAME;
const apiKey = import.meta.env.SECRET_CLOUDINARY_API_KEY || process.env.SECRET_CLOUDINARY_API_KEY;
const apiSecret = import.meta.env.SECRET_CLOUDINARY_API_SECRET || process.env.SECRET_CLOUDINARY_API_SECRET;

cloudinary.config({
  cloud_name: cloudName,
  api_key: apiKey,
  api_secret: apiSecret,
  secure: true
});

const { resources } = await cloudinary.search
  .expression('folder:SHLLC-Gallery')
  .with_field('context')  
  .with_field('image_metadata') 
  .max_results(100)
  .execute();

const galleryItems: GalleryItem[] = resources.map((image: any) => {
  const optimizedUrl = image.secure_url.replace(
    '/upload/',
    '/upload/c_scale,w_400,h_400,f_auto,q_auto/' 
  );

  return {
    url: optimizedUrl,
    largeUrl: image.secure_url,
    publicId: image.public_id,
    date: image.image_metadata?.DateTimeOriginal 
      ? new Date(image.image_metadata.DateTimeOriginal) 
      : new Date(image.created_at),
  };
});

const sortedGallery = galleryItems.sort((a: GalleryItem, b: GalleryItem) => b.date.getTime() - a.date.getTime());
---

<Layout title="Gallery">
  <Container>
    <div class="bg-cover bg-center py-12 drop-shadow-sm">
      <Sectionhead>
        <Fragment slot="title">Gallery</Fragment>
        <Fragment slot="desc"></Fragment>
      </Sectionhead>
    </div>

    {/* FIXED: Added id="photo-gallery" so the light-box script knows which container tracks target items */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="photo-gallery">
      {sortedGallery.map((item) => (
        /* FIXED: Wrapped items in anchor tags specifying large dimension properties */
        <a 
          href={item.largeUrl} 
          target="_blank" 
          data-pswp-width="1600" 
          data-pswp-height="1200" 
          class="bg-black rounded-lg overflow-hidden border-2 border-zinc-800 flex flex-col group transition-transform duration-200"
        >
          <div class="aspect-video w-full overflow-hidden">
            <img 
              src={item.url} 
              alt="Southard Homes construction project" 
              class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          
          <div class="p-4 text-white mt-auto bg-black flex justify-between items-center text-sm">
            <span>Date added: {item.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
          </div>
        </a>
      ))}
    </div>
  </Container>
</Layout>

<script>
  // Import PhotoSwipe styles and core controller assets directly into the client runtime
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#photo-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe')
  });
  
  // Initialize on page run
  lightbox.init();
</script>